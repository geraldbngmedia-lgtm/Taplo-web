{
  "name": "interview-intelligence-workspace",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "desktop": "concurrently \"npm run dev -- --hostname 127.0.0.1\" \"wait-on http://127.0.0.1:3000 && node electron-start.js\"",
    "build": "next build",
    "postbuild": "node scripts/copy-standalone.js",
    "dist": "cross-env BUILD_TARGET=electron npm run build && electron-builder",
    "start": "next start",
    "lint": "eslint ."
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.9",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.2.4",
    "lucide-react": "^0.468.0",
    "next": "^16.2.4",
    "postcss": "^8.4.49",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.taplo.interview",
    "productName": "Taplo",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/brand/taplo-logo-full-color.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "public/brand/taplo-logo-full-color.png",
      "category": "public.app-category.productivity"
    },
    "publish": {
      "provider": "github",
      "owner": "geraldbngmedia-lgtm",
      "repo": "Taplo-desktop"
    }
  }
}
